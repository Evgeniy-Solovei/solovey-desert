# SECRET_KEY должен быть уникальным и секретным на боевом сервере.
SECRET_KEY=change-me-before-production
DEBUG=False

# Домены, с которых Django разрешает открывать сайт.
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,solovey-desert.by,www.solovey-desert.by

# Домены, с которых разрешены POST-запросы с CSRF-защитой.
CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1,https://solovey-desert.by,https://www.solovey-desert.by
TIME_ZONE=Europe/Minsk

# -----------------------------------------------------------------------------
# HTTPS and cookies
# -----------------------------------------------------------------------------
# В production cookies должны передаваться только по HTTPS.
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True

# HSTS говорит браузеру всегда открывать сайт по HTTPS.
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False

# -----------------------------------------------------------------------------
# Cart
# -----------------------------------------------------------------------------
# Корзина хранится по cookie, чтобы пользователь видел её после возвращения.
CART_COOKIE_AGE=15552000
CART_COOKIE_SECURE=True
CART_MAX_ITEM_QUANTITY=99

# -----------------------------------------------------------------------------
# Site metadata and SEO
# -----------------------------------------------------------------------------
# Эти значения используются в meta-тегах, sitemap.xml, robots.txt и Schema.org.
SITE_URL=https://solovey-desert.by
SITE_NAME=Solovey Desert
SITE_DESCRIPTION=Авторские торты, десерты, конфеты и подарочные наборы ручной работы в Минске.
SITE_PHONE=+375 (29) 599-44-66
SITE_EMAIL=solovey.desert@example.com
SITE_CITY=Минск

# -----------------------------------------------------------------------------
# Domain and SSL certificates
# -----------------------------------------------------------------------------
# Эти значения использует nginx/certbot для HTTPS-сертификата.
DOMAIN_NAME=solovey-desert.by
DOMAIN_WWW=www.solovey-desert.by

# Перед первым выпуском Let's Encrypt сертификата замени на реальный email.
LETSENCRYPT_EMAIL=admin@example.com

# -----------------------------------------------------------------------------
# Analytics and webmaster verification
# -----------------------------------------------------------------------------
# Для Яндекс Метрики нужен только ID счётчика, не весь HTML-код из Яндекса.
YANDEX_METRICA_ID=

# Коды подтверждения прав на сайт из Яндекс Вебмастера и Google Search Console.
# Для Google Search Console берётся content из meta-тега:
# <meta name="google-site-verification" content="..." />
YANDEX_WEBMASTER_VERIFICATION=
GOOGLE_SITE_VERIFICATION=

# Google Analytics 4. Сюда нужен Measurement ID вида G-XXXXXXXXXX.
GOOGLE_ANALYTICS_ID=

# -----------------------------------------------------------------------------
# PostgreSQL inside Docker
# -----------------------------------------------------------------------------
# Эти данные использует контейнер db и Django web-контейнер.
POSTGRES_DB=solovey_desert_db
POSTGRES_USER=solovey_desert_user
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgres://solovey_desert_user:change-me-postgres-password@db:5432/solovey_desert_db
